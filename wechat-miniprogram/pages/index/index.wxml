<view class="container">
  <!-- 进入页弹窗提醒 -->
  <view wx:if="{{showPopup}}" class="popup-overlay">
    <view class="popup-content">
      <text class="popup-title">免责声明</text>
      <view class="popup-message">
        <rich-text nodes="<p><strong>⚠️风险提示：</strong>本工具仅供学习研究使用，使用前请确认您已获得车辆制造商的授权。任何未经授权的操作可能影响车辆系统稳定性，由此产生的后果由用户自行承担。</p><p><strong>重要声明：</strong>本工具不提供任何破解、刷机或修改系统的功能，仅展示公开的技术信息供参考。使用本工具即表示您同意遵守相关法律法规和车辆使用条款。</p><p><strong>适用范围：</strong>本工具适用于捷途部分车型的技术信息查询。</p><p><strong>特别提醒：</strong>不同车型和版本的技术参数可能不同，请根据实际情况参考使用。</p><p><strong>版权声明：</strong>本工具仅用于个人学习研究，请勿用于商业用途。</p>"></rich-text>
      </view>
      <button bindtap="closePopup" class="popup-button">我已知晓</button>
    </view>
  </view>

  <view class="header">
    <text class="title">车机口令工具</text>
  </view>

  <view class="link-buttons">
    <button class="link-button" bindtap="openManual">使用教程</button>
    <button class="link-button" bindtap="openTool">安装工具</button>
  </view>

  <!-- 车型选择 -->
  <view class="selector-row">
    <text class="section-title-inline">车型：</text>
    <picker
      mode="selector"
      range="{{carModelList}}"
      range-key="label"
      value="{{carModelIndex}}"
      bindchange="onCarModelChange"
      class="car-picker-inline"
    >
      <view class="picker-value-inline">
        {{carModelList[carModelIndex].label}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 车机系统版本选择 -->
  <view class="selector-row">
    <text class="section-title-inline">车机系统版本：</text>
    <picker
      mode="selector"
      range="{{versionList}}"
      range-key="label"
      value="{{versionIndex}}"
      bindchange="onVersionChange"
      class="version-picker-inline"
    >
      <view class="picker-value-inline">
        {{versionList[versionIndex].label}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <view class="hour-password-group">
    <view class="hour-indicator">
      口令有效期：
      <text wx:if="{{!isCountdownMode}}" class="highlight">{{nextUpdateTime}}</text>
      <text wx:else class="highlight countdown">{{countdownDisplay}}</text>
    </view>

    <view class="password-group">
      <view class="password-card">
        <text class="card-title">1. 系统口令</text>
        <text class="password-value">{{carPassword}}</text>
        <text class="instructions">{{carInstructions}}</text>
      </view>

      <view class="password-card">
        <text class="card-title">2. 设置口令</text>

        <view wx:if="{{currentVersion === '00x'}}" class="serial-number-input">
          <input
            type="text"
            placeholder="请输入序列号后六位"
            bindinput="inputSerialNumber"
            maxlength="6"
          />
          <button class="calculate-button" bindtap="calculatePassword">计算口令</button>
        </view>

        <view wx:if="{{currentCarModel === 'g700' && !g700ShowAdb}}" class="serial-number-input">
          <input
            type="text"
            placeholder="请输入密码"
            bindinput="inputG700VerifyPassword"
            maxlength="6"
          />
          <button class="calculate-button" bindtap="verifyG700Password">验证</button>
          <text wx:if="{{g700VerifyError}}" class="error-text">密码错误</text>
        </view>

        <text class="password-value">{{settingPassword}}</text>

        

        <text class="instructions">{{settingInstructions}}</text>
      </view>
    </view>
  </view>

  <view class="update-info">
    <text>最后更新时间：{{updateTime}}</text>
  </view>
</view>
